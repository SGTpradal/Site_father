#cloud-config
autoinstall:
  version: 1

  identity:
    hostname: virtus-web-01
    username: virtusadm
    password: "$6$P/q59wEt2xyRiPL2$r1Z3T2MuiiZGRPx.NafVlrbarWLlGzBs1yJWBpmoATGeJ1ZC0dKIW4JQ2jNW5rJG5HcVfBY7mNOlGhNn/dXt.0"

  locale: pt_BR.UTF-8
  keyboard:
    layout: br

  timezone: America/Sao_Paulo

  ssh:
    install-server: true
    allow-pw: true

  packages:
    - openssh-server
    - nginx
    - ufw
    - curl
    - unzip
    - git
    - net-tools
    - htop
    - certbot
    - python3-certbot-nginx

  network:
    version: 2
    ethernets:
      ens18:
        dhcp4: false
        addresses:
          - 192.168.10.50/24
        routes:
          - to: default
            via: 192.168.10.1
        nameservers:
          addresses:
            - 1.1.1.1
            - 8.8.8.8

  late-commands:
    - curtin in-target --target=/target -- bash -c "apt update"
    - curtin in-target --target=/target -- bash -c "apt install -y nodejs npm"

    # Firewall
    - curtin in-target --target=/target -- bash -c "ufw allow 22/tcp"
    - curtin in-target --target=/target -- bash -c "ufw allow 80/tcp"
    - curtin in-target --target=/target -- bash -c "ufw allow 443/tcp"
    - curtin in-target --target=/target -- bash -c "ufw --force enable"

    # Estrutura do site
    - curtin in-target --target=/target -- bash -c "mkdir -p /var/www/virtus/public"
    - curtin in-target --target=/target -- bash -c "chown -R www-data:www-data /var/www/virtus"
    - curtin in-target --target=/target -- bash -c "chmod -R 755 /var/www/virtus"

    # Página temporária
    - curtin in-target --target=/target -- bash -c "echo '<h1>Virtus Web Server OK</h1>' > /var/www/virtus/public/index.html"

    # Nginx
    - curtin in-target --target=/target -- bash -c "cat > /etc/nginx/sites-available/virtus <<'EOF'
      server {
          listen 80;
          server_name virtusgestao.srv.br www.virtusgestao.srv.br;

          root /var/www/virtus/public;
          index index.html;

          location / {
              try_files \$uri \$uri/ /index.html;
          }

          location /api/ {
              proxy_pass http://127.0.0.1:3000/;
              proxy_http_version 1.1;
              proxy_set_header Upgrade \$http_upgrade;
              proxy_set_header Connection 'upgrade';
              proxy_set_header Host \$host;
              proxy_cache_bypass \$http_upgrade;
          }
      }
      EOF"

    - curtin in-target --target=/target -- bash -c "ln -sf /etc/nginx/sites-available/virtus /etc/nginx/sites-enabled/virtus"
    - curtin in-target --target=/target -- bash -c "rm -f /etc/nginx/sites-enabled/default"
    - curtin in-target --target=/target -- bash -c "nginx -t"
    - curtin in-target --target=/target -- bash -c "systemctl enable nginx"
    - curtin in-target --target=/target -- bash -c "systemctl restart nginx"

    # Backend Node.js base
    - curtin in-target --target=/target -- bash -c "cat > /var/www/virtus/package.json <<'EOF'
      {
        \"name\": \"virtus-site\",
        \"version\": \"1.0.0\",
        \"main\": \"server.js\",
        \"scripts\": {
          \"start\": \"node server.js\"
        },
        \"dependencies\": {
          \"express\": \"latest\",
          \"cors\": \"latest\",
          \"dotenv\": \"latest\",
          \"nodemailer\": \"latest\"
        }
      }
      EOF"

    - curtin in-target --target=/target -- bash -c "cat > /var/www/virtus/server.js <<'EOF'
      const express = require('express');
      const cors = require('cors');
      const nodemailer = require('nodemailer');
      require('dotenv').config();

      const app = express();

      app.use(cors());
      app.use(express.json());
      app.use(express.urlencoded({ extended: true }));

      app.get('/health', (req, res) => {
        res.json({ status: 'ok', service: 'virtus-site' });
      });

      app.post('/contato', async (req, res) => {
        try {
          const { nome, email, telefone, mensagem } = req.body;

          if (!nome || !email || !mensagem) {
            return res.status(400).json({ error: 'Campos obrigatórios ausentes.' });
          }

          const transporter = nodemailer.createTransport({
            host: process.env.SMTP_HOST,
            port: Number(process.env.SMTP_PORT),
            secure: process.env.SMTP_SECURE === 'true',
            auth: {
              user: process.env.SMTP_USER,
              pass: process.env.SMTP_PASS
            }
          });

          await transporter.sendMail({
            from: process.env.SMTP_FROM,
            to: 'contato@virtusgestao.srv.br',
            subject: 'Nova mensagem pelo site Virtus',
            text: `
      Nome: ${nome}
      Email: ${email}
      Telefone: ${telefone || 'Não informado'}

      Mensagem:
      ${mensagem}
            `
          });

          res.json({ success: true });
        } catch (error) {
          console.error(error);
          res.status(500).json({ error: 'Erro ao enviar mensagem.' });
        }
      });

      app.listen(3000, '127.0.0.1', () => {
        console.log('Virtus backend rodando em http://127.0.0.1:3000');
      });
      EOF"

    - curtin in-target --target=/target -- bash -c "cat > /var/www/virtus/.env <<'EOF'
      SMTP_HOST=smtp.seudominio.com
      SMTP_PORT=587
      SMTP_SECURE=false
      SMTP_USER=usuario@seudominio.com
      SMTP_PASS=SENHA_DO_EMAIL
      SMTP_FROM=contato@virtusgestao.srv.br
      EOF"

    - curtin in-target --target=/target -- bash -c "cd /var/www/virtus && npm install"

    # Systemd do backend
    - curtin in-target --target=/target -- bash -c "cat > /etc/systemd/system/virtus-site.service <<'EOF'
      [Unit]
      Description=Virtus Site Backend
      After=network.target

      [Service]
      Type=simple
      WorkingDirectory=/var/www/virtus
      ExecStart=/usr/bin/node /var/www/virtus/server.js
      Restart=always
      RestartSec=5
      User=www-data
      Group=www-data
      Environment=NODE_ENV=production

      [Install]
      WantedBy=multi-user.target
      EOF"

    - curtin in-target --target=/target -- bash -c "chown -R www-data:www-data /var/www/virtus"
    - curtin in-target --target=/target -- bash -c "systemctl daemon-reload"
    - curtin in-target --target=/target -- bash -c "systemctl enable virtus-site"
    - curtin in-target --target=/target -- bash -c "systemctl start virtus-site"
